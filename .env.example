# ── Shared JWT ──
# Genera una clave con: openssl rand -base64 32
JWT_SIGNING_KEY=changeme-generate-with-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# ── PostgreSQL ──
POSTGRES_DB=lite
POSTGRES_USER=lite
POSTGRES_PASSWORD=lite
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
PRODUCT_EVENTS_STREAM=product-events

# ── Django ──
# Genera una clave con: openssl rand -base64 32
DJANGO_SECRET_KEY=changeme-generate-with-openssl-rand-base64-32
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── LLM Provider (ollama | openai) ──
LLM_PROVIDER=ollama

# Local Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_EMBED_MODEL=nomic-embed-text

EMBEDDING_DIMENSIONS=768

# OpenAI (solo si LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-5.4-mini-2026-03-17

# ── Email (Resend) ──
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=onboarding@resend.dev

# ── Service-to-service internal token subject ──
INTERNAL_SERVICE_SUBJECT=django-service

# ── Blockchain (Anvil local dev) ──
WEB3_RPC_URL=http://anvil:8545
WEB3_CHAIN_ID=31337
# Clave de prueba por defecto de Anvil (NO usar en producción)
WEB3_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
SOLC_VERSION=0.8.24
