        <mxCell id="fe" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=8;fontSize=12;" value="frontend — Next.js (App Router, Atomic Design)&lt;br&gt;&lt;br&gt;Vistas: login · companies · products · inventory · agent&lt;br&gt;atoms / molecules / organisms / templates&lt;br&gt;lib/api.ts → UN cliente, adjunta el MISMO Bearer&lt;br&gt;lib/auth.tsx → lee el claim rol del JWT (UI por rol)" vertex="1">
          <mxGeometry height="120" width="620" x="600" y="180" as="geometry" />
        </mxCell>
